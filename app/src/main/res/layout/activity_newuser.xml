<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Register"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>


    <EditText
        android:id="@+id/editTextFirstName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="First Name"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editTextLastName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Last Name"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editTextNumberAge"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Age"
        android:inputType="number"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editTextAddress"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Address"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editTextNewUserName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Username"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/editTextNewUserPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:layout_marginBottom="16dp"/>


    <RadioGroup
        android:id="@+id/radioGroupDisabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/radioButtonYes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disabled: Yes"/>

        <RadioButton
            android:id="@+id/radioButtonNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No"/>
    </RadioGroup>


    <CheckBox
        android:id="@+id/checkBoxElectricVehicle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Own Electric Vehicle"
        android:layout_marginBottom="16dp"/>


    <TextView
        android:id="@+id/textViewMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/design_default_color_error"
        android:layout_marginBottom="16dp"/>


    <Button
        android:id="@+id/buttonSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Sign Up"
        android:backgroundTint="#2D6CDF"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/buttonBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="#2D6CDF"
        android:text="Back"/>

</LinearLayout>